{
  "name": "imessage-pi-agent",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:runner": "pnpm --filter @imessage-pi-agent/mac-runner dev",
